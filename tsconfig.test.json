{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.test.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": ["node"],
    "skipLibCheck": true,
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "rootDir": ".",
    "outDir": "test-dist"
  },
  "include": [
    "tests/**/*.ts",
    "client/src/types/shareSnapshot.ts",
    "client/src/utils/shareSnapshot.ts",
    "server/src/**/*.ts",
    "shared/**/*.ts"
  ]
}
